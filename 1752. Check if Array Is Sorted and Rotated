class Solution(object):
    def check(self, nums):
        """
        :type nums: List[int]
        :rtype: bool
        """
        drop_count = 0
        current_num = nums[0]
        for x in range(1,len(nums)):
            if current_num > nums[x]:
                drop_count +=1
            current_num = nums[x]
        
        if current_num > nums[0]:
           drop_count += 1
        
        if drop_count <= 1:
           return True
        else:
            return False

            


    
