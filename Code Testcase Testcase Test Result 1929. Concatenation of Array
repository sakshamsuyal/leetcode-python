class Solution(object):
    def getConcatenation(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        newarr = []
        for i in range(len(nums)):
            newarr.append(nums[i])
        for i in range(len(nums)):
            newarr.append(nums[i])
        return newarr

            
