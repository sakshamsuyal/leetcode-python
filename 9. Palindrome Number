class Solution(object):
    def isPalindrome(self, x):
        """
        :type x: int
        :rtype: bool
        """
        rev = 0
        original = x
        if x<0:
          return False
        while x > 0:
           last = x%10
           rev = rev*10+last
           x=x//10
        if original == rev:
          return True
        else:
          return False
        
        
